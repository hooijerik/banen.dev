# Public site URL (used for canonical URLs, sitemap, JSON-LD)
NEXT_PUBLIC_SITE_URL=https://gtmbanen.nl

# Optional: override the SQLite database path (defaults to ./data/gtmbanen.db)
# GTMBANEN_DB=./data/gtmbanen.db

# Email via Resend (https://resend.com/api-keys) for alert digests + employer-submission
# notifications. If RESEND_API_KEY is unset, emails are logged (dry-run) instead of sent.
# RESEND_API_KEY=re_xxxxxxxx
# Sender address on your VERIFIED Resend domain. Use a bare address (no spaces) so it
# loads cleanly in cron/systemd; the "GTM Banen" display name is added automatically.
# ALERTS_FROM_EMAIL=vacatures@gtmbanen.nl
# Where employer job submissions + premium expiry reminders are emailed:
# SUBMISSIONS_TO_EMAIL=info@gtmai.nl

# Admin area (/admin) for managing premium placements. Set a long random secret (>=8 chars);
# when unset, /admin is disabled. Generate with: openssl rand -hex 24
# ADMIN_TOKEN=change-me-to-a-long-random-secret

# Optional: USD -> EUR conversion rate used when aggregating non-EUR salaries.
SALARY_USD_EUR_RATE=0.92
